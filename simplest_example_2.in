# Initialize
units lj
atom_style molecular
boundary p p p
pair_style lj/cut 2.5

# Define the simulation box
region box block 0 20 0 20 0 20
create_box 2 box

# Create a central atom (type 1) and surrounding atoms (type 2)
create_atoms 1 single 10 10 10  # Central atom (type 1)
create_atoms 2 single 11 11 11  # Atom 1 (type 2, offset along +x +y +z)
create_atoms 2 single 9 11 11   # Atom 2 (type 2, offset along -x +y +z)
create_atoms 2 single 11 9 11   # Atom 3 (type 2, offset along +x -y +z)
create_atoms 2 single 11 11 9   # Atom 4 (type 2, offset along +x +y -z)

# Define interactions between atoms (optional for inter-molecular)

pair_coeff 1 1 1.0 1.0 2.5  # Central-central using Lennard-Jones
pair_coeff 2 2 1.0 1.0 2.5  # Attached-attached using Lennard-Jones
pair_coeff 1 2 1.0 1.0 2.5  # Central-attached using Lennard-Jones

mass 1 1.0  # Central atom mass
mass 2 1.0  # Peripheral atoms mass

# Define the rigid body group (group all atoms belonging to the molecule)
group rigid_molecule id 1 2 3 4 5

# Apply rigid body dynamics to the molecule
fix 1 rigid_molecule rigid/nve

# Replicate the molecule across the simulation box
replicate 3 3 3  # Replicate molecules in a 3x3x3 grid

# Output initial configuration
write_data rigid_molecule.data
dump 1 all atom 10 rigid_molecule.lammpstrj

# Run a short simulation
thermo 100
run 1000

